---
const rows = [
  { feature: 'Token Savings', leanctx: '89-99%', rtk: '60-90% CLI only', orbital: '20-25%' },
  { feature: 'Scope', leanctx: 'Files + CLI + Search', rtk: 'Shell output', orbital: 'Chat panel' },
  { feature: 'Session Caching', leanctx: 'MD5-based', rtk: 'None', orbital: 'None' },
  { feature: 'Signature Mode', leanctx: 'TS / JS / Svelte', rtk: 'None', orbital: 'None' },
  { feature: 'Diff Mode', leanctx: 'Line-level diffs', rtk: 'None', orbital: 'None' },
  { feature: 'Context Compress', leanctx: 'Checkpoint snapshots', rtk: 'None', orbital: 'None' },
  { feature: 'Dashboard', leanctx: 'Charts + History', rtk: 'None', orbital: 'Basic' },
  { feature: 'Token Counting', leanctx: 'tiktoken (exact)', rtk: 'Estimated', orbital: 'None' },
  { feature: 'MCP Native', leanctx: 'Yes', rtk: 'No (shell hook)', orbital: 'Yes' },
  { feature: 'Multi-Editor', leanctx: 'Cursor, Copilot, Claude, Windsurf', rtk: 'Cursor only', orbital: 'Cursor only' },
  { feature: 'Open Source', leanctx: 'Yes (MIT)', rtk: 'Yes', orbital: 'No' },
];
---

<section class="relative py-28 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-bg via-surface/20 to-bg pointer-events-none"></div>

  <div class="relative max-w-5xl mx-auto px-6">
    <div class="text-center mb-20">
      <h2 class="text-3xl sm:text-4xl font-bold mb-5">How We Compare</h2>
      <p class="text-muted text-lg max-w-2xl mx-auto leading-relaxed">
        Session caching, signature extraction, context compression, and diff-based updates
        deliver savings no other tool can match.
      </p>
    </div>

    <div class="rounded-2xl glass-strong overflow-hidden terminal-glow">
      <div class="overflow-x-auto">
        <table class="w-full">
          <thead>
            <tr class="border-b border-border/50">
              <th class="text-left text-xs uppercase tracking-widest text-muted/60 font-medium py-5 px-6">Feature</th>
              <th class="text-left text-xs uppercase tracking-widest font-semibold py-5 px-6 text-accent bg-accent/5">lean-ctx</th>
              <th class="text-left text-xs uppercase tracking-widest text-muted/60 font-medium py-5 px-6">RTK</th>
              <th class="text-left text-xs uppercase tracking-widest text-muted/60 font-medium py-5 px-6">OrbitalMCP</th>
            </tr>
          </thead>
          <tbody>
            {rows.map(row => (
              <tr class="border-b border-border/30 last:border-b-0 hover:bg-accent/[0.02] transition-colors">
                <td class="py-3.5 px-6 text-sm font-medium text-text">{row.feature}</td>
                <td class="py-3.5 px-6 text-sm font-semibold text-accent bg-accent/[0.03]">{row.leanctx}</td>
                <td class="py-3.5 px-6 text-sm text-muted">{row.rtk}</td>
                <td class="py-3.5 px-6 text-sm text-muted">{row.orbital}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>
