---
const year = new Date().getFullYear();
---

<footer class="border-t border-border bg-bg">
  <div class="max-w-7xl mx-auto px-6 py-12">
    <div class="grid md:grid-cols-4 gap-8 mb-8">
      <div>
        <div class="flex items-center gap-2 mb-4">
          <span class="text-lg font-bold text-text">lean</span>
          <span class="text-lg font-light text-accent">-ctx</span>
        </div>
        <p class="text-sm text-muted leading-relaxed">
          Smart Context MCP Server. Reduces LLM token consumption by 89-99%.
        </p>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-text mb-3">Product</h4>
        <ul class="space-y-2">
          <li><a href="/features" class="text-sm text-muted hover:text-accent transition-colors">Features</a></li>
          <li><a href="/pricing" class="text-sm text-muted hover:text-accent transition-colors">Pricing</a></li>
          <li><a href="/blog" class="text-sm text-muted hover:text-accent transition-colors">Blog</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-text mb-3">Documentation</h4>
        <ul class="space-y-2">
          <li><a href="/docs/getting-started" class="text-sm text-muted hover:text-accent transition-colors">Getting Started</a></li>
          <li><a href="/docs/installation" class="text-sm text-muted hover:text-accent transition-colors">Installation</a></li>
          <li><a href="/docs/tools" class="text-sm text-muted hover:text-accent transition-colors">Tool Reference</a></li>
          <li><a href="/docs/configuration" class="text-sm text-muted hover:text-accent transition-colors">Configuration</a></li>
        </ul>
      </div>

      <div>
        <h4 class="text-sm font-semibold text-text mb-3">Community</h4>
        <ul class="space-y-2">
          <li><a href="https://gitlab.pounce.ch/root/lean-ctx" target="_blank" rel="noopener" class="text-sm text-muted hover:text-accent transition-colors">GitLab</a></li>
          <li><a href="https://gitlab.pounce.ch/root/lean-ctx/-/issues" target="_blank" rel="noopener" class="text-sm text-muted hover:text-accent transition-colors">Issues</a></li>
        </ul>
      </div>
    </div>

    <div class="border-t border-border pt-8 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-muted">&copy; {year} lean-ctx. MIT License.</p>
      <p class="text-xs text-muted">Built for developers who care about token efficiency.</p>
    </div>
  </div>
</footer>
