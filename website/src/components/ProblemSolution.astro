<section class="relative py-28 overflow-hidden">
  <div class="absolute inset-0 bg-gradient-to-b from-bg via-surface/30 to-bg pointer-events-none"></div>

  <div class="relative max-w-7xl mx-auto px-6">
    <div class="text-center mb-20">
      <h2 class="text-3xl sm:text-4xl font-bold mb-5">The Token Problem</h2>
      <p class="text-muted text-lg max-w-2xl mx-auto leading-relaxed">
        AI coding tools send your entire codebase to the LLM on every interaction.
        Thousands of tokens wasted on files already in context.
      </p>
    </div>

    <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
      <!-- Without -->
      <div class="card-premium rounded-2xl p-8">
        <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-danger/5 to-transparent pointer-events-none"></div>
        <div class="relative">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-11 h-11 rounded-xl bg-danger/10 border border-danger/20 flex items-center justify-center">
              <svg class="w-5 h-5 text-danger" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
              </svg>
            </div>
            <h3 class="text-lg font-bold text-danger">Without lean-ctx</h3>
          </div>
          <ul class="space-y-4 text-sm text-muted">
            <li class="flex items-start gap-3">
              <span class="mt-1 w-1.5 h-1.5 rounded-full bg-danger/60 flex-shrink-0"></span>
              <span>Reading same file twice: <strong class="text-text">3,517 tokens</strong></span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 w-1.5 h-1.5 rounded-full bg-danger/60 flex-shrink-0"></span>
              <span>Checking dependency API: <strong class="text-text">2,536 tokens</strong></span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 w-1.5 h-1.5 rounded-full bg-danger/60 flex-shrink-0"></span>
              <span>git status output: <strong class="text-text">100+ characters</strong></span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 w-1.5 h-1.5 rounded-full bg-danger/60 flex-shrink-0"></span>
              <span>Project structure: <strong class="text-text">980 tokens</strong></span>
            </li>
          </ul>
          <div class="mt-6 pt-5 border-t border-danger/10">
            <p class="text-sm font-bold text-danger">~7,000 tokens per typical interaction</p>
          </div>
        </div>
      </div>

      <!-- With -->
      <div class="card-premium rounded-2xl p-8">
        <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-accent/5 to-accent-2/3 pointer-events-none"></div>
        <div class="relative">
          <div class="flex items-center gap-3 mb-6">
            <div class="w-11 h-11 rounded-xl bg-accent/10 border border-accent/20 flex items-center justify-center">
              <svg class="w-5 h-5 text-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <h3 class="text-lg font-bold gradient-text-accent">With lean-ctx</h3>
          </div>
          <ul class="space-y-4 text-sm text-muted">
            <li class="flex items-start gap-3">
              <span class="mt-1 w-1.5 h-1.5 rounded-full bg-accent/60 flex-shrink-0"></span>
              <span>Reading same file twice: <strong class="text-accent">13 tokens</strong> (cached)</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 w-1.5 h-1.5 rounded-full bg-accent/60 flex-shrink-0"></span>
              <span>Checking dependency API: <strong class="text-accent">252 tokens</strong> (signatures)</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 w-1.5 h-1.5 rounded-full bg-accent/60 flex-shrink-0"></span>
              <span>git status output: <strong class="text-accent">31 characters</strong> (compressed)</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1 w-1.5 h-1.5 rounded-full bg-accent/60 flex-shrink-0"></span>
              <span>Project structure: <strong class="text-accent">588 tokens</strong> (compact)</span>
            </li>
          </ul>
          <div class="mt-6 pt-5 border-t border-accent/10">
            <p class="text-sm font-bold gradient-text-accent">~884 tokens — 87% reduction</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
