---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description: string;
  date: string;
  author?: string;
}

const { title, description, date, author = 'lean-ctx team' } = Astro.props;
const formattedDate = new Date(date).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={`${title} — lean-ctx Blog`} description={description}>
  <article class="max-w-3xl mx-auto px-6 py-24">
    <header class="mb-14">
      <a href="/blog" class="text-sm text-muted hover:text-accent transition-colors duration-300 mb-6 inline-block">&larr; Back to Blog</a>
      <h1 class="text-3xl sm:text-4xl font-extrabold tracking-tight mb-5 text-text-bright">{title}</h1>
      <div class="flex items-center gap-3 text-sm text-muted/60">
        <span>{formattedDate}</span>
        <span>&middot;</span>
        <span>{author}</span>
      </div>
    </header>

    <div class="
      [&_h2]:text-xl [&_h2]:font-semibold [&_h2]:mt-10 [&_h2]:mb-4 [&_h2]:text-text-bright
      [&_h3]:text-lg [&_h3]:font-medium [&_h3]:mt-8 [&_h3]:mb-3 [&_h3]:text-text-bright
      [&_p]:text-muted [&_p]:leading-relaxed [&_p]:mb-5
      [&_a]:text-accent [&_a]:underline [&_a]:underline-offset-2
      [&_code]:bg-surface-2 [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded-md [&_code]:text-accent-2 [&_code]:text-sm [&_code]:border [&_code]:border-border/30
      [&_pre]:bg-surface [&_pre]:border [&_pre]:border-border/30 [&_pre]:rounded-xl [&_pre]:p-5 [&_pre]:overflow-x-auto [&_pre]:mb-6
      [&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_pre_code]:border-0
      [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-5 [&_ul]:text-muted
      [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:mb-5 [&_ol]:text-muted
      [&_li]:mb-2 [&_li]:leading-relaxed
      [&_strong]:text-text-bright [&_strong]:font-semibold
      [&_blockquote]:border-l-2 [&_blockquote]:border-accent/40 [&_blockquote]:pl-4 [&_blockquote]:text-muted [&_blockquote]:italic
    ">
      <slot />
    </div>
  </article>
</BaseLayout>
