---
import BaseLayout from './BaseLayout.astro';
import DocsSidebar from '../components/DocsSidebar.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<BaseLayout title={`${title} — lean-ctx Docs`} description={description}>
  <div class="max-w-7xl mx-auto px-6 py-16 lg:grid lg:grid-cols-[240px_1fr] lg:gap-12">
    <DocsSidebar />
    <article class="prose prose-invert max-w-none
      [&_h1]:text-3xl [&_h1]:font-bold [&_h1]:mb-6 [&_h1]:text-text
      [&_h2]:text-xl [&_h2]:font-semibold [&_h2]:mt-10 [&_h2]:mb-4 [&_h2]:text-text
      [&_h3]:text-lg [&_h3]:font-medium [&_h3]:mt-8 [&_h3]:mb-3 [&_h3]:text-text
      [&_p]:text-muted [&_p]:leading-relaxed [&_p]:mb-4
      [&_a]:text-accent [&_a]:underline [&_a]:underline-offset-2
      [&_code]:bg-surface [&_code]:px-1.5 [&_code]:py-0.5 [&_code]:rounded [&_code]:text-accent-2 [&_code]:text-sm
      [&_pre]:bg-surface [&_pre]:border [&_pre]:border-border [&_pre]:rounded-lg [&_pre]:p-4 [&_pre]:overflow-x-auto [&_pre]:mb-6
      [&_pre_code]:bg-transparent [&_pre_code]:p-0
      [&_ul]:list-disc [&_ul]:pl-6 [&_ul]:mb-4 [&_ul]:text-muted
      [&_ol]:list-decimal [&_ol]:pl-6 [&_ol]:mb-4 [&_ol]:text-muted
      [&_li]:mb-1
      [&_table]:w-full [&_table]:mb-6
      [&_th]:text-left [&_th]:text-xs [&_th]:uppercase [&_th]:tracking-wider [&_th]:text-muted [&_th]:pb-3 [&_th]:border-b [&_th]:border-border
      [&_td]:py-2.5 [&_td]:text-sm [&_td]:border-b [&_td]:border-border
      [&_blockquote]:border-l-2 [&_blockquote]:border-accent [&_blockquote]:pl-4 [&_blockquote]:text-muted [&_blockquote]:italic
      ">
      <h1>{title}</h1>
      <slot />
    </article>
  </div>
</BaseLayout>
