---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLocaleFromUrl, getLocalizedPath } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const lp = (path: string) => getLocalizedPath(path, locale);
---

<BaseLayout title="LeanCTX Cloud Login" description="Complete your LeanCTX Cloud login.">
  <section class="content-grid py-12 md:py-16">
    <div class="max-w-3xl mx-auto">
      <div class="glass-panel p-8 md:p-10 animate-entrance">
        <h1 class="text-2xl md:text-3xl font-display text-text-bright">Redirecting…</h1>
        <p class="mt-3 text-sm text-muted">
          Bitte öffne <a class="text-accent underline" href={lp('/dashboard')}>/dashboard</a> und melde dich dort mit deiner E‑Mail an.
        </p>
      </div>
    </div>
  </section>

  <script type="module" define:vars={{ cloudUrl: lp('/dashboard') }}>
    // Magic-link exchange is not used in the current public API.
    // Keep this route for old links and redirect to the dashboard.
    window.location.replace(cloudUrl);
  </script>
</BaseLayout>

