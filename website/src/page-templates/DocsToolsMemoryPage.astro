---
import DocsLayout from '../layouts/DocsLayout.astro';
import { getLocaleFromUrl, getLocalizedPath, useTranslations } from '../i18n/utils';

const locale = getLocaleFromUrl(Astro.url);
const t = useTranslations(locale);
const lp = (path: string) => getLocalizedPath(path, locale);

const sidebar = [
  {
    title: t('docsToolsMemory.sidebarTitle'),
    compact: true,
    items: [
      { label: 'ctx_knowledge', href: lp('/docs/tools/memory') + '#ctx_knowledge' },
      { label: 'ctx_agent', href: lp('/docs/tools/memory') + '#ctx_agent' },
      { label: 'ctx_share', href: lp('/docs/tools/memory') + '#ctx_share' },
      { label: 'ctx_overview', href: lp('/docs/tools/memory') + '#ctx_overview' },
    ],
  },
  {
    title: t('docsToolsCore.sidebarOther'),
    items: [
      { label: t('docsToolsCore.sidebarAllTools'), href: lp('/docs/tools') },
      { label: t('docsToolsCore.sidebarTitle'), href: lp('/docs/tools/core') },
      { label: t('docsToolsCore.sidebarIntelligence'), href: lp('/docs/tools/intelligence') },
      { label: t('docsToolsCore.sidebarSession'), href: lp('/docs/tools/session') },
    ],
  },
];
---

<DocsLayout title={t('docsToolsMemory.title')} description={t('docsToolsMemory.description')} sidebar={sidebar}>
  <p>{t('docsToolsMemory.intro')}</p>

  <h2 id="ctx_knowledge">ctx_knowledge — Persistent Project Knowledge</h2>
  <p>
    A persistent key-value knowledge store scoped to each project. Facts, patterns, and conventions
    survive across sessions, enabling the LLM to build cumulative project understanding.
  </p>

  <h3>{t('docsToolsCore.parameters')}</h3>
  <table>
    <thead>
      <tr><th>Action</th><th>{t('docsToolsCore.parameters')}</th><th>{t('docsToolsCore.thDescription')}</th></tr>
    </thead>
    <tbody>
      <tr><td><code>remember</code></td><td><code>category</code>, <code>key</code>, <code>value</code>, <code>confidence</code></td><td>Store a project fact with optional confidence score</td></tr>
      <tr><td><code>recall</code></td><td><code>query</code> OR <code>category</code></td><td>Search facts by text or list by category</td></tr>
      <tr><td><code>pattern</code></td><td><code>pattern_type</code>, <code>value</code>, <code>examples</code></td><td>Record a project convention or pattern</td></tr>
      <tr><td><code>consolidate</code></td><td>—</td><td>Extract session findings/decisions into permanent knowledge</td></tr>
      <tr><td><code>status</code></td><td>—</td><td>Show all stored knowledge summary</td></tr>
      <tr><td><code>remove</code></td><td><code>category</code>, <code>key</code></td><td>Delete an outdated fact</td></tr>
      <tr><td><code>export</code></td><td>—</td><td>Export all knowledge as structured data</td></tr>
    </tbody>
  </table>

  <h3>Example</h3>
  <pre><code>ctx_knowledge action=remember category=architecture key=auth value="JWT with refresh tokens, 7-day expiry" confidence=0.95
→ Stored: architecture/auth (confidence: 0.95)

ctx_knowledge action=recall query="authentication"
→ 1 result:
  architecture/auth — JWT with refresh tokens, 7-day expiry (0.95)

ctx_knowledge action=consolidate
→ Consolidated 3 findings + 1 decision into permanent knowledge</code></pre>

  <h3>Storage</h3>
  <p>
    Knowledge is stored per-project at <code>~/.lean-ctx/knowledge/&lt;project-hash&gt;/knowledge.json</code>.
  </p>

  <h2 id="ctx_agent">ctx_agent — Multi-Agent Context Sharing</h2>
  <p>
    Coordinates multiple concurrent AI agents working on the same project.
    Agents register themselves, share findings via a scratchpad, and track each other's status.
  </p>

  <h3>{t('docsToolsCore.parameters')}</h3>
  <table>
    <thead>
      <tr><th>Action</th><th>{t('docsToolsCore.parameters')}</th><th>{t('docsToolsCore.thDescription')}</th></tr>
    </thead>
    <tbody>
      <tr><td><code>register</code></td><td><code>agent_type</code>, <code>role</code></td><td>Register this agent at session start</td></tr>
      <tr><td><code>list</code></td><td>—</td><td>Show other active agents on this project</td></tr>
      <tr><td><code>post</code></td><td><code>message</code>, <code>category</code>, <code>tags</code></td><td>Share findings/warnings with other agents</td></tr>
      <tr><td><code>read</code></td><td>—</td><td>Check for new messages from other agents</td></tr>
      <tr><td><code>status</code></td><td><code>status</code> (<code>active</code>/<code>idle</code>/<code>finished</code>), <code>message</code></td><td>Update work status</td></tr>
      <tr><td><code>info</code></td><td>—</td><td>Show registry summary</td></tr>
      <tr><td><code>handoff</code></td><td><code>to_agent</code>, <code>message</code></td><td>Transfer task to another agent with summary</td></tr>
      <tr><td><code>sync</code></td><td>—</td><td>Multi-agent sync status: active agents, pending messages, shared contexts</td></tr>
    </tbody>
  </table>

  <h3>Example</h3>
  <pre><code>ctx_agent action=register agent_type=cursor role="implementing auth module"
→ Registered: cursor-a3f8 (role: implementing auth module)

ctx_agent action=post message="auth.ts refactored — new export: verifyJWT" category=change tags=["auth","breaking"]
→ Posted to scratchpad (1 other agent online)

ctx_agent action=handoff to_agent=claude message="auth module complete, needs review"
→ Handoff: cursor-a3f8 → claude | Status: finished

ctx_agent action=sync
→ Multi-Agent Sync Status:
  Active agents: 2 | Pending messages: 1 | Shared contexts: 3</code></pre>

  <h3>Storage</h3>
  <p>
    Agent registry and scratchpad are stored at <code>~/.lean-ctx/agents/registry.json</code>.
  </p>

  <h2 id="ctx_share">ctx_share — Multi-Agent Context Sharing</h2>
  <p>
    Enables agents to share cached file contents with each other. When one agent has read and cached files,
    it can push them to another agent, avoiding redundant file reads and enabling efficient task handoffs.
  </p>

  <h3>{t('docsToolsCore.parameters')}</h3>
  <table>
    <thead>
      <tr><th>Action</th><th>{t('docsToolsCore.parameters')}</th><th>{t('docsToolsCore.thDescription')}</th></tr>
    </thead>
    <tbody>
      <tr><td><code>push</code></td><td><code>paths</code>, <code>to_agent</code>, <code>message</code></td><td>Share cached file contexts with a specific agent or all agents</td></tr>
      <tr><td><code>pull</code></td><td>—</td><td>Receive shared contexts from other agents</td></tr>
      <tr><td><code>list</code></td><td>—</td><td>List all shared contexts across agents</td></tr>
      <tr><td><code>clear</code></td><td>—</td><td>Remove contexts shared by this agent</td></tr>
    </tbody>
  </table>

  <h3>Example</h3>
  <pre><code>ctx_share action=push paths="src/auth.ts,src/middleware.ts" to_agent=claude message="auth files for review"
→ Shared 2 files with claude (1,247 tokens)

ctx_share action=pull
→ 1 shared context from cursor-a3f8:
  src/auth.ts (892 tok) + src/middleware.ts (355 tok)
  Message: "auth files for review"</code></pre>

  <h3>Storage</h3>
  <p>
    Shared contexts are stored at <code>~/.lean-ctx/agents/shared/</code> as JSON files.
  </p>

  <h2 id="ctx_overview">ctx_overview — Task-Aware Project Map</h2>
  <p>
    Provides a multi-resolution project map at session start. Uses the dependency graph and keyword
    matching to group files by task relevance into tiers (critical / important / reference / skip).
    Recommends the optimal <code>ctx_read</code> mode per file, so the LLM can load context efficiently
    from the first tool call.
  </p>

  <h3>{t('docsToolsCore.parameters')}</h3>
  <table>
    <thead>
      <tr><th>{t('docsToolsCore.thParameter')}</th><th>{t('docsToolsCore.thType')}</th><th>{t('docsToolsCore.thRequired')}</th><th>{t('docsToolsCore.thDescription')}</th></tr>
    </thead>
    <tbody>
      <tr><td><code>task</code></td><td>string</td><td>No</td><td>Description of current task (improves relevance ranking)</td></tr>
      <tr><td><code>path</code></td><td>string</td><td>No</td><td>Project root path (defaults to cwd)</td></tr>
    </tbody>
  </table>

  <h3>Example</h3>
  <pre><code>ctx_overview task="fix JWT token refresh bug"
→ PROJECT OVERVIEW — /Users/you/project (142 files)

  CRITICAL (read full):
    src/auth.ts — JWT logic, token generation
    src/middleware.ts — token validation

  IMPORTANT (read map):
    src/routes.ts — auth route handlers
    src/lib/session.ts — session management

  REFERENCE (read signatures):
    src/lib/db.ts — database layer
    src/config.ts — JWT config values

  SKIP (67 files):
    tests/, docs/, scripts/, ...</code></pre>
</DocsLayout>
