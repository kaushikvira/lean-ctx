---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found — lean-ctx">
  <div class="max-w-xl mx-auto px-6 py-32 text-center">
    <p class="text-6xl font-extrabold text-accent mb-4">404</p>
    <h1 class="text-2xl font-bold mb-4">Page Not Found</h1>
    <p class="text-muted mb-8">The page you're looking for doesn't exist or has been moved.</p>
    <a href="/" class="inline-flex items-center px-6 py-3 text-sm font-semibold rounded-lg bg-accent text-bg hover:bg-accent/90 transition-all">
      Back to Home
    </a>
  </div>
</BaseLayout>
