---
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = [
  {
    slug: 'why-ai-coding-tools-waste-tokens',
    title: 'Why AI Coding Tools Waste 90% of Your Tokens',
    description: 'AI coding assistants send thousands of redundant tokens per interaction. Here\'s why it happens and how lean-ctx fixes it.',
    date: '2026-03-19',
    author: 'lean-ctx team',
  },
];
---

<BaseLayout title="Blog — lean-ctx" description="Articles about token optimization, MCP servers, and AI coding efficiency.">
  <div class="relative max-w-3xl mx-auto px-6 py-24">
    <h1 class="text-3xl font-extrabold tracking-tight mb-4 text-text-bright">Blog</h1>
    <p class="text-muted text-lg mb-14 leading-relaxed">Insights on token optimization, MCP servers, and AI-assisted development.</p>

    <div class="space-y-6">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="block group card-premium rounded-2xl p-7 hover:border-accent/20">
          <div class="relative">
            <div class="flex items-center gap-3 text-xs text-muted/50 mb-3">
              <time datetime={post.date}>{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
              <span>&middot;</span>
              <span>{post.author}</span>
            </div>
            <h2 class="text-xl font-bold mb-3 text-text-bright group-hover:text-accent transition-colors duration-300">{post.title}</h2>
            <p class="text-sm text-muted leading-relaxed">{post.description}</p>
          </div>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
