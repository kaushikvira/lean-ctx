---
import BaseLayout from '../../layouts/BaseLayout.astro';

const posts = [
  {
    slug: 'why-ai-coding-tools-waste-tokens',
    title: 'Why AI Coding Tools Waste 90% of Your Tokens',
    description: 'AI coding assistants send thousands of redundant tokens per interaction. Here\'s why it happens and how lean-ctx fixes it.',
    date: '2026-03-19',
    author: 'lean-ctx team',
  },
];
---

<BaseLayout title="Blog — lean-ctx" description="Articles about token optimization, MCP servers, and AI coding efficiency.">
  <div class="max-w-3xl mx-auto px-6 py-20">
    <h1 class="text-3xl font-extrabold tracking-tight mb-4">Blog</h1>
    <p class="text-muted text-lg mb-12">Insights on token optimization, MCP servers, and AI-assisted development.</p>

    <div class="space-y-8">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="block group rounded-xl border border-border bg-surface p-6 hover:border-accent/40 transition-all">
          <div class="flex items-center gap-3 text-xs text-muted mb-3">
            <time datetime={post.date}>{new Date(post.date).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
            <span>&middot;</span>
            <span>{post.author}</span>
          </div>
          <h2 class="text-xl font-bold mb-2 group-hover:text-accent transition-colors">{post.title}</h2>
          <p class="text-sm text-muted leading-relaxed">{post.description}</p>
        </a>
      ))}
    </div>
  </div>
</BaseLayout>
