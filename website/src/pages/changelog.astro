---
import BaseLayout from '../layouts/BaseLayout.astro';

const releases = [
  {
    version: '1.5.1',
    date: 'March 24, 2026',
    tag: 'Bug Fix',
    tagColor: 'text-red-400 bg-red-400/10 border-red-400/20',
    title: 'Fix recursive alias loop causing SIGABRT',
    link: 'https://github.com/yvgude/lean-ctx/releases/tag/v1.5.1',
    highlights: [
      'Fixed critical bug where <code>lean-ctx init --global</code> caused git commands to hang and crash on fish shell and some Linux configurations',
      'Added <code>LEAN_CTX_ACTIVE</code> env var guard to prevent infinite recursion in subprocess spawning',
      'CLI commands no longer spin up a tokio multi-threaded runtime — only MCP server and dashboard use async',
      'Shell aliases from <code>init --global</code> are now wrapped in a guard condition for fish, bash, and zsh',
    ],
    details: 'Fish shell always loads <code>config.fish</code> even for non-interactive shells, causing the aliases to re-trigger lean-ctx in an infinite loop. The fix works at the binary level (passthrough mode) so even existing unguarded alias installations are protected.',
  },
  {
    version: '1.5.0',
    date: 'March 24, 2026',
    tag: 'Major Feature',
    tagColor: 'text-accent bg-accent/10 border-accent/20',
    title: 'Tree-sitter AST-based Signature Extraction',
    link: 'https://github.com/yvgude/lean-ctx/releases/tag/v1.5.0',
    highlights: [
      'Integrated <a href="/docs/tree-sitter" class="text-accent hover:underline">tree-sitter</a> for AST-powered code analysis across 10 languages',
      'Supports Rust, TypeScript, JavaScript, Python, Go, Java, C, C++, Ruby',
      'Correctly handles multi-line signatures, arrow functions, nested classes, and visibility modifiers',
      'Regex-based extraction remains as automatic fallback for unsupported languages (Svelte, Vue, etc.)',
      'Optional Cargo feature flag — build without tree-sitter using <code>--no-default-features</code> for a ~5.7 MB binary',
    ],
    details: 'The previous regex-based signature extraction was brittle for complex code patterns. Tree-sitter provides a proper Abstract Syntax Tree, enabling accurate extraction of function signatures, class definitions, impl blocks, type aliases, and more. Each language uses hand-crafted SCM queries optimized for the structures developers care about.',
  },
  {
    version: '1.4.1',
    date: 'March 24, 2026',
    tag: 'Patch',
    tagColor: 'text-yellow-400 bg-yellow-400/10 border-yellow-400/20',
    title: 'Dashboard Branding, Pattern Router & Metrics Accuracy',
    link: 'https://github.com/yvgude/lean-ctx/releases/tag/v1.4.1',
    highlights: [
      'Fixed dashboard branding (was still showing old project name in some places)',
      'Pattern router now correctly dispatches all 50+ compression patterns',
      'Metrics accuracy improved — <code>ctx_metrics</code> tool now reflects actual session data',
      'Website documentation audit and cross-link fixes',
    ],
    details: null,
  },
  {
    version: '1.4.0',
    date: 'March 24, 2026',
    tag: 'Major Feature',
    tagColor: 'text-accent bg-accent/10 border-accent/20',
    title: '50+ Compression Patterns, New CLI Commands & Homebrew',
    link: null,
    highlights: [
      '<strong>50+ shell compression patterns</strong> covering git, docker, npm/pnpm/yarn, cargo, kubectl, gh CLI, pip, linters, build tools, test runners, and more',
      'New CLI commands: <code>discover</code> (find uncompressed commands in history), <code>session</code> (adoption stats), <code>config</code> (configuration management)',
      '<strong>Homebrew support</strong>: <code>brew install yvgude/lean-ctx/lean-ctx</code>',
      'Full comparison table vs. RTK in README and website',
      'Discord community launch',
    ],
    details: 'This release transformed lean-ctx from a pure MCP server into a hybrid architecture with transparent CLI compression. Any shell command output can be piped through lean-ctx for automatic token reduction.',
  },
  {
    version: '1.3.2',
    date: 'March 24, 2026',
    tag: 'Docs',
    tagColor: 'text-blue-400 bg-blue-400/10 border-blue-400/20',
    title: 'Complete Documentation & leanctx.com Launch',
    link: null,
    highlights: [
      'Comprehensive documentation for all 8 MCP tools with examples',
      'Token Dense Dialect (TDD) section added to crates.io README',
      'All links updated to <a href="https://leanctx.com" class="text-accent hover:underline">leanctx.com</a>',
    ],
    details: null,
  },
  {
    version: '1.3.1',
    date: 'March 24, 2026',
    tag: 'Enhancement',
    tagColor: 'text-purple-400 bg-purple-400/10 border-purple-400/20',
    title: 'TDD in All 8 MCP Tools',
    link: null,
    highlights: [
      'Token Dense Dialect output mode now available in all 8 MCP tools',
      'Consistent symbol shorthand across <code>ctx_read</code>, <code>ctx_tree</code>, <code>ctx_shell</code>, <code>ctx_search</code>, <code>ctx_compress</code>, <code>ctx_analyze</code>, <code>ctx_benchmark</code>, <code>ctx_metrics</code>',
    ],
    details: null,
  },
  {
    version: '1.3.0',
    date: 'March 24, 2026',
    tag: 'Major Feature',
    tagColor: 'text-accent bg-accent/10 border-accent/20',
    title: 'Token Dense Dialect (TDD)',
    link: null,
    highlights: [
      'Introduced <a href="/docs/tdd" class="text-accent hover:underline">Token Dense Dialect</a> — a compressed output format using symbol shorthand',
      'Symbol table mapping (<code>§MAP</code>) for compact identifier references',
      'Uses symbols like <code>→ ∴ ≈ ✓ ✗ λ ∂ §</code> to maximize information density',
      'Configurable via MCP instructions (<code>CRP MODE: tdd</code>)',
    ],
    details: 'TDD is a response formatting protocol that tells lean-ctx to output in the most token-efficient form possible. Articles, filler words, and pleasantries are stripped. Identifiers are mapped to short IDs. Tabular format is used for structured data.',
  },
  {
    version: '1.2.2',
    date: 'March 23, 2026',
    tag: 'Enhancement',
    tagColor: 'text-purple-400 bg-purple-400/10 border-purple-400/20',
    title: 'Auto-Checkpoint & Mandatory MCP Instructions',
    link: null,
    highlights: [
      'Auto-checkpoint every 10 tool calls — compresses session context automatically',
      'MCP server instructions are now mandatory and injected into every session',
      'Full tool call tracking across all 8 MCP tools',
    ],
    details: 'The auto-checkpoint feature creates compressed summaries of session state at regular intervals, preventing context windows from growing unboundedly in long coding sessions.',
  },
  {
    version: '1.2.1',
    date: 'March 23, 2026',
    tag: 'Enhancement',
    tagColor: 'text-purple-400 bg-purple-400/10 border-purple-400/20',
    title: 'Dashboard & Full MCP Tracking',
    link: null,
    highlights: [
      'Restored web dashboard command (<code>lean-ctx dashboard</code>)',
      'All 8 MCP tools now tracked in persistent statistics',
      'Dashboard shows per-tool savings breakdown',
    ],
    details: null,
  },
  {
    version: '1.2.0',
    date: 'March 23, 2026',
    tag: 'Major Feature',
    tagColor: 'text-accent bg-accent/10 border-accent/20',
    title: 'Web Dashboard & Persistent MCP Stats',
    link: null,
    highlights: [
      '<a href="/docs/dashboard" class="text-accent hover:underline">Web dashboard</a> at <code>localhost:3333</code> for real-time token savings visualization',
      'Persistent statistics stored in <code>~/.lean-ctx/stats.json</code>',
      'Simplified MCP server instructions for better LLM compliance',
      'Daily aggregates and per-command breakdowns',
    ],
    details: 'The dashboard provides a visual overview of cumulative token savings, most-compressed commands, daily usage patterns, and adoption metrics.',
  },
  {
    version: '1.1.1',
    date: 'March 23, 2026',
    tag: 'Patch',
    tagColor: 'text-yellow-400 bg-yellow-400/10 border-yellow-400/20',
    title: 'Fix GitHub Repository URL & MCP Version',
    link: null,
    highlights: [
      'Corrected GitHub repository URL on crates.io metadata',
      'Fixed MCP server version string',
      'Fixed grep quoting issue in CLI',
    ],
    details: null,
  },
  {
    version: '1.1.0',
    date: 'March 23, 2026',
    tag: 'Major Feature',
    tagColor: 'text-accent bg-accent/10 border-accent/20',
    title: 'Full CLI Parity & Public Release',
    link: null,
    highlights: [
      'Published on <a href="https://crates.io/crates/lean-ctx" class="text-accent hover:underline">crates.io</a> and <a href="https://github.com/yvgude/lean-ctx" class="text-accent hover:underline">GitHub</a>',
      'Full CLI command suite: <code>gain</code>, <code>init</code>, <code>read</code>, <code>diff</code>, <code>grep</code>, <code>find</code>, <code>ls</code>, <code>deps</code>',
      '<code>lean-ctx init --global</code> for one-command shell integration',
      'Updated website with CLI documentation',
    ],
    details: 'This release marked the transition from an internal tool to a publicly available package. All install instructions were updated for cargo and source builds.',
  },
  {
    version: '1.0.0',
    date: 'March 23, 2026',
    tag: 'Major Release',
    tagColor: 'text-accent bg-accent/10 border-accent/20',
    title: 'Complete Rust Rewrite — Hybrid Architecture',
    link: null,
    highlights: [
      '<strong>Full rewrite in Rust</strong> — single binary, no Node.js runtime needed',
      'Hybrid architecture: MCP server + shell hook in one binary',
      'Dependency map mode with structured headers',
      'Session-aware caching with file references (<code>F1</code>, <code>F2</code>, ...)',
      'Compact Response Protocol (CRP) v2',
    ],
    details: 'The Rust rewrite eliminated the need for a separate Node.js runtime, reduced startup time to near-zero, and enabled the hybrid shell hook architecture that intercepts and compresses CLI output transparently.',
  },
  {
    version: '0.5.0',
    date: 'March 23, 2026',
    tag: 'Feature',
    tagColor: 'text-teal-400 bg-teal-400/10 border-teal-400/20',
    title: 'Entropy Compression & ctx_analyze',
    link: null,
    highlights: [
      'Shannon entropy filtering for intelligent content reduction',
      'Jaccard deduplication to collapse similar code blocks',
      '<code>ctx_analyze</code> tool for optimal read mode recommendation',
    ],
    details: null,
  },
  {
    version: '0.4.0',
    date: 'March 23, 2026',
    tag: 'Feature',
    tagColor: 'text-teal-400 bg-teal-400/10 border-teal-400/20',
    title: 'ctx_compress Tool',
    link: null,
    highlights: [
      'New <code>ctx_compress</code> MCP tool for on-demand text compression',
      'Token cost guide documentation',
      'Optimized Cursor rule for lean-ctx integration',
    ],
    details: null,
  },
  {
    version: '0.3.0',
    date: 'March 23, 2026',
    tag: 'Feature',
    tagColor: 'text-teal-400 bg-teal-400/10 border-teal-400/20',
    title: 'Dashboard, CLI & Persistence',
    link: null,
    highlights: [
      'First version of the web dashboard',
      'CLI interface for direct usage',
      'Persistent statistics across sessions',
      'GitHub Copilot support',
    ],
    details: null,
  },
  {
    version: '0.2.0',
    date: 'March 23, 2026',
    tag: 'Feature',
    tagColor: 'text-teal-400 bg-teal-400/10 border-teal-400/20',
    title: 'Token Counter, Compact Protocol & Benchmarks',
    link: null,
    highlights: [
      'tiktoken-based accurate token counting',
      'Compact Response Protocol (CRP) for structured output',
      '<code>ctx_benchmark</code> tool for comparing compression modes',
    ],
    details: null,
  },
  {
    version: '0.1.0',
    date: 'March 23, 2026',
    tag: 'Initial Release',
    tagColor: 'text-emerald-400 bg-emerald-400/10 border-emerald-400/20',
    title: 'lean-ctx MCP Server v0.1.0',
    link: null,
    highlights: [
      'First release of the lean-ctx MCP Server',
      'Core <code>ctx_read</code> tool with caching and signature extraction',
      '<code>ctx_search</code> and <code>ctx_tree</code> tools',
      'Basic compression: diff-updates, signature-only mode, syntax stripping',
    ],
    details: 'The initial concept: an MCP server that sits between the IDE and the LLM, compressing file contents and tool outputs to reduce token consumption while preserving the information the model actually needs.',
  },
];
---

<BaseLayout title="Changelog — LeanCTX" description="Full version history of LeanCTX. Every feature, fix, and improvement documented.">
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-16 sm:py-24">

    <div class="text-center mb-16">
      <span class="inline-block px-3 py-1 text-xs font-semibold uppercase tracking-widest text-accent bg-accent/10 border border-accent/20 rounded-full mb-6">Version History</span>
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight text-text-bright mb-4">Changelog</h1>
      <p class="text-lg text-muted max-w-2xl mx-auto">Every release, feature, and fix — from the first MCP server prototype to today's hybrid Rust architecture with tree-sitter AST parsing.</p>
    </div>

    <div class="relative">
      <div class="absolute left-[19px] top-0 bottom-0 w-px bg-gradient-to-b from-accent/40 via-border/60 to-transparent hidden sm:block"></div>

      <div class="space-y-12">
        {releases.map((release, i) => (
          <article class="relative sm:pl-14">
            <div class="absolute left-0 top-1 hidden sm:flex items-center justify-center">
              <div class:list={[
                'w-10 h-10 rounded-xl flex items-center justify-center border',
                i === 0 ? 'bg-accent/15 border-accent/30' : 'bg-surface-2 border-border/40'
              ]}>
                <svg class:list={['w-4.5 h-4.5', i === 0 ? 'text-accent' : 'text-muted']} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  {release.tag === 'Bug Fix' ? (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4c-.77-.833-1.964-.833-2.732 0L4.082 16.5c-.77.833.192 2.5 1.732 2.5z"/>
                  ) : release.tag === 'Patch' ? (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/>
                  ) : (
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"/>
                  )}
                </svg>
              </div>
            </div>

            <div class:list={[
              'rounded-2xl border p-6 sm:p-8 transition-all duration-300',
              i === 0 ? 'bg-surface border-accent/20 shadow-lg shadow-accent/5' : 'bg-surface border-border/40 hover:border-border/60'
            ]}>
              <div class="flex flex-wrap items-center gap-3 mb-4">
                <span class="text-2xl font-bold text-text-bright font-mono">v{release.version}</span>
                <span class:list={['px-2.5 py-0.5 text-xs font-semibold rounded-full border', release.tagColor]}>{release.tag}</span>
                <span class="text-sm text-muted">{release.date}</span>
                {release.link && (
                  <a href={release.link} target="_blank" rel="noopener" class="ml-auto text-xs text-muted hover:text-accent transition-colors flex items-center gap-1">
                    <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
                    Release
                  </a>
                )}
              </div>

              <h2 class="text-lg font-semibold text-text-bright mb-4">{release.title}</h2>

              <ul class="space-y-2 mb-4">
                {release.highlights.map(h => (
                  <li class="flex items-start gap-2.5 text-sm text-muted">
                    <svg class="w-4 h-4 text-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                    <span set:html={h} />
                  </li>
                ))}
              </ul>

              {release.details && (
                <div class="mt-4 pt-4 border-t border-border/30">
                  <p class="text-sm text-muted/80 leading-relaxed" set:html={release.details} />
                </div>
              )}
            </div>
          </article>
        ))}
      </div>
    </div>

    <div class="mt-16 text-center">
      <p class="text-muted mb-6">Want to see what's coming next?</p>
      <div class="flex justify-center gap-4 flex-wrap">
        <a href="https://github.com/yvgude/lean-ctx/issues" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium rounded-lg btn-outline-glossy text-text hover:text-text-bright transition-all">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z"/></svg>
          GitHub Issues
        </a>
        <a href="https://discord.gg/pTHkG9Hew9" target="_blank" rel="noopener" class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium rounded-lg border border-[#5865F2]/40 text-[#5865F2] hover:bg-[#5865F2]/10 hover:border-[#5865F2]/60 transition-all">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M20.317 4.37a19.791 19.791 0 00-4.885-1.515.074.074 0 00-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 00-5.487 0 12.64 12.64 0 00-.617-1.25.077.077 0 00-.079-.037A19.736 19.736 0 003.677 4.37a.07.07 0 00-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 00.031.057 19.9 19.9 0 005.993 3.03.078.078 0 00.084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 00-.041-.106 13.107 13.107 0 01-1.872-.892.077.077 0 01-.008-.128 10.2 10.2 0 00.372-.292.074.074 0 01.077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 01.078.01c.12.098.246.198.373.292a.077.077 0 01-.006.127 12.299 12.299 0 01-1.873.892.077.077 0 00-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 00.084.028 19.839 19.839 0 006.002-3.03.077.077 0 00.032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 00-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"/></svg>
          Join Discord
        </a>
      </div>
    </div>

  </section>
</BaseLayout>
