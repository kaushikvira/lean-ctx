---
import BaseLayout from '../layouts/BaseLayout.astro';

const tiers = [
  {
    name: 'Free',
    price: '$0',
    period: 'forever',
    description: 'Everything you need to save tokens locally.',
    features: [
      '6 MCP Tools (ctx_read, ctx_tree, ctx_shell, ctx_benchmark, ctx_metrics, ctx_compress)',
      'Session caching with MD5 hashing',
      'All compression modes (signatures, diff, aggressive)',
      'Context checkpoint compression',
      'Local dashboard with charts',
      'CLI (dashboard, stats, init)',
      'Cursor, Copilot, Claude Code, Windsurf support',
      'Unlimited projects',
      'MIT licensed — fully open source',
    ],
    cta: 'Get Started',
    ctaHref: '/docs/getting-started',
    highlight: false,
  },
  {
    name: 'Pro',
    price: '$9',
    period: '/month',
    description: 'Cloud dashboard and team features for power users.',
    features: [
      'Everything in Free, plus:',
      'Cloud Dashboard — access stats from anywhere',
      'Cross-device sync of token savings',
      'Team analytics — aggregate stats across members',
      'Historical data retention (unlimited)',
      'Priority support',
      'Early access to new features',
    ],
    cta: 'Join Waitlist',
    ctaHref: '#waitlist',
    highlight: true,
  },
  {
    name: 'Enterprise',
    price: 'Custom',
    period: '',
    description: 'Self-hosted deployment with custom integrations.',
    features: [
      'Everything in Pro, plus:',
      'Self-hosted cloud dashboard',
      'Custom compression patterns',
      'SSO / SAML authentication',
      'Admin controls and audit logs',
      'Dedicated support and SLA',
      'Custom onboarding',
    ],
    cta: 'Contact Us',
    ctaHref: 'mailto:hello@lean-ctx.dev',
    highlight: false,
  },
];
---

<BaseLayout title="Pricing — lean-ctx" description="lean-ctx is free and open source. Pro plans add cloud dashboard, team analytics, and cross-device sync.">
  <div class="relative max-w-7xl mx-auto px-6 py-24">
    <!-- Background orbs -->
    <div class="orb w-[350px] h-[350px] bg-accent-2/10 top-[50px] left-[20%]" style="animation-delay: -4s;"></div>
    <div class="orb w-[250px] h-[250px] bg-accent/10 bottom-[30%] right-[10%]" style="animation-delay: -11s;"></div>

    <div class="relative text-center mb-20">
      <h1 class="text-4xl sm:text-5xl font-extrabold tracking-tight mb-5">Simple <span class="gradient-text">Pricing</span></h1>
      <p class="text-lg text-muted max-w-2xl mx-auto leading-relaxed">
        The core tool is free and open source. Forever. Pro features add cloud capabilities for teams.
      </p>
    </div>

    <div class="relative grid md:grid-cols-3 gap-6 max-w-5xl mx-auto">
      {tiers.map(tier => (
        <div class:list={[
          'rounded-2xl p-8 flex flex-col relative',
          tier.highlight
            ? 'glass-strong'
            : 'card-premium'
        ]}>
          {tier.highlight && (
            <Fragment>
              <div class="absolute inset-0 rounded-2xl bg-gradient-to-b from-accent/8 to-accent-2/5 pointer-events-none"></div>
              <div class="absolute -inset-[1px] rounded-2xl bg-gradient-to-b from-accent/30 via-accent-2/20 to-accent-3/10 -z-10"></div>
              <div class="absolute -top-3.5 left-1/2 -translate-x-1/2 px-5 py-1.5 rounded-full bg-gradient-to-r from-accent to-accent-2 text-bg text-xs font-bold shadow-lg shadow-accent/20">
                Coming Soon
              </div>
            </Fragment>
          )}

          <div class="relative mb-8">
            <h3 class="text-lg font-bold mb-3 text-text-bright">{tier.name}</h3>
            <div class="flex items-baseline gap-1">
              <span class:list={['text-4xl font-extrabold', tier.highlight ? 'gradient-text' : 'text-text-bright']}>
                {tier.price}
              </span>
              {tier.period && <span class="text-sm text-muted">{tier.period}</span>}
            </div>
            <p class="mt-3 text-sm text-muted leading-relaxed">{tier.description}</p>
          </div>

          <ul class="relative space-y-3.5 mb-10 flex-1">
            {tier.features.map(f => (
              <li class="flex items-start gap-2.5 text-sm">
                <svg class:list={['w-4 h-4 mt-0.5 flex-shrink-0', tier.highlight ? 'text-accent' : 'text-accent/50']} fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                </svg>
                <span class="text-muted">{f}</span>
              </li>
            ))}
          </ul>

          <a
            href={tier.ctaHref}
            class:list={[
              'relative block text-center py-3.5 px-6 rounded-xl text-sm font-bold transition-all',
              tier.highlight
                ? 'btn-glossy text-bg'
                : 'btn-outline-glossy text-text'
            ]}
          >
            {tier.cta}
          </a>
        </div>
      ))}
    </div>

    <!-- Waitlist Section -->
    <section id="waitlist" class="relative mt-28 max-w-xl mx-auto text-center scroll-mt-24">
      <h2 class="text-2xl font-bold mb-4 text-text-bright">Join the Pro Waitlist</h2>
      <p class="text-muted mb-8 leading-relaxed">
        Be the first to know when the cloud dashboard launches. No spam, just one email when it's ready.
      </p>
      <form class="flex gap-3" action="https://formspree.io/f/your-form-id" method="POST">
        <input
          type="email"
          name="email"
          required
          placeholder="you@company.com"
          class="flex-1 px-5 py-3.5 rounded-xl glass border border-border text-text placeholder-muted/50 text-sm focus:outline-none focus:border-accent/40 transition-all"
        />
        <button type="submit" class="btn-glossy px-7 py-3.5 rounded-xl text-bg text-sm font-bold">
          Notify Me
        </button>
      </form>
    </section>
  </div>
</BaseLayout>
